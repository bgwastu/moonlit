{
  "name": "moonlit",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "signalsmith": "node scripts/signalsmith.mjs",
    "predev": "node scripts/signalsmith.mjs",
    "prebuild": "node scripts/signalsmith.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@mantine/colors-generator": "9.4.1",
    "@mantine/core": "9.4.1",
    "@mantine/dropzone": "9.4.1",
    "@mantine/form": "9.4.1",
    "@mantine/hooks": "9.4.1",
    "@mantine/notifications": "9.4.1",
    "@tabler/icons-react": "^3.44.0",
    "id3-parser": "^3.0.0",
    "localforage": "^1.10.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "signalsmith-stretch": "^1.3.2",
    "typescript": "^5.7.3",
    "undici": "^8.7.0",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.10.1",
    "@types/react": "19",
    "@types/react-dom": "19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "bunx eslint --max-warnings=0",
      "bunx prettier --write"
    ],
    "*.{json,css,md}": "bunx prettier --write"
  },
  "overrides": {
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom"
  }
}
